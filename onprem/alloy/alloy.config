prometheus.exporter.cadvisor "docker" {
  docker_only      = true
  disabled_metrics = [
    "advtcp", "cpuLoad", "cpu_topology", "cpuset", "diskIO",
    "hugetlb", "memory_numa", "oom_event", "percpu", "perf_event",
    "process", "referenced_memory", "resctrl", "sched", "tcp", "udp",
  ]
}

prometheus.scrape "cadvisor" {
  targets         = prometheus.exporter.cadvisor.docker.targets
  forward_to      = [prometheus.relabel.add_labels.receiver]
  scrape_interval = "60s"
}

prometheus.relabel "add_labels" {
  forward_to = [prometheus.remote_write.aws.receiver]

  rule {
    target_label = "job"
    replacement  = "integrations/cadvisor"
  }
  rule {
    target_label = "host"
    replacement  = "poc-containers"
  }
}

// Push cAdvisor container metrics straight to the AWS Prometheus remote_write
// receiver via the metrics-proxy push-proxy on :9552 (nginx forwards
// /api/v1/write to prometheus.mcp.local:9090 over the VPN). Requires
// --web.enable-remote-write-receiver on the AWS Prometheus ECS task.
// This replaces the old local :9528 prometheus-relay + AWS federation path.
//
// NOTE: the rust-pricing worker is NOT pushed from here — AWS Prometheus PULLS
// it through metrics-proxy :9550 (/rust-pricing/metrics; job 'rustpricing' in
// images/prometheus/prometheus.yml). Pushing it here too would double-ingest.
prometheus.remote_write "aws" {
  endpoint {
    url = "http://192.168.164.184:9552/api/v1/write"
  }
}
