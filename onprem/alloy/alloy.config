prometheus.exporter.cadvisor "docker" {
  docker_only      = true
  disabled_metrics = [
    "advtcp", "cpuLoad", "cpu_topology", "cpuset", "diskIO",
    "hugetlb", "memory_numa", "oom_event", "percpu", "perf_event",
    "process", "referenced_memory", "resctrl", "sched", "tcp", "udp",
  ]
}

prometheus.scrape "cadvisor" {
  targets         = prometheus.exporter.cadvisor.docker.targets
  forward_to      = [prometheus.relabel.add_host.receiver]
  scrape_interval = "60s"
}

prometheus.relabel "add_host" {
  forward_to = [prometheus.remote_write.local.receiver]

  rule {
    target_label = "host"
    replacement  = env("ALLOY_HOST_LABEL")
  }
}

// Rust pricing worker (k3s, .195 subnet). The AWS Prometheus cannot route the
// .195 ingress over the VPN, but poc-containers can — so we scrape it here and
// remote_write the series into the AWS Prometheus alongside the cAdvisor data.
// Forwarded straight to remote_write (not via add_host) so it keeps its own
// instance label rather than being tagged host=poc-containers.
prometheus.scrape "rustpricing" {
  targets = [
    { "__address__" = "rust-pricing.apps.cgp3.co.uk:443", "instance" = "rust-pricing-worker" },
  ]
  scheme          = "https"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.remote_write.local.receiver]

  tls_config {
    insecure_skip_verify = true
  }
}

prometheus.remote_write "local" {
  endpoint {
    url = "http://192.168.8.3:9500/api/v1/write"
  }
}
