prometheus.exporter.cadvisor "docker" {
  docker_only      = true
  disabled_metrics = [
    "advtcp", "cpuLoad", "cpu_topology", "cpuset", "diskIO",
    "hugetlb", "memory_numa", "oom_event", "percpu", "perf_event",
    "process", "referenced_memory", "resctrl", "sched", "tcp", "udp",
  ]
}

prometheus.scrape "cadvisor" {
  targets         = prometheus.exporter.cadvisor.docker.targets
  forward_to      = [prometheus.relabel.add_labels.receiver]
  scrape_interval = "60s"
}

prometheus.relabel "add_labels" {
  forward_to = [prometheus.remote_write.relay.receiver]

  rule {
    target_label = "job"
    replacement  = "integrations/cadvisor"
  }
  rule {
    target_label = "host"
    replacement  = "poc-containers"
  }
}

// Rust pricing worker (k3s, .195 subnet). The AWS Prometheus cannot route the
// .195 ingress over the VPN, but poc-containers can — so we scrape it here and
// push it through the same relay the cAdvisor metrics use, into the AWS store.
prometheus.scrape "rustpricing" {
  targets = [
    { "__address__" = "rust-pricing.apps.cgp3.co.uk:443", "instance" = "rust-pricing-worker" },
  ]
  scheme          = "https"
  metrics_path    = "/metrics"
  scrape_interval = "15s"
  forward_to      = [prometheus.relabel.rustpricing_federable.receiver]

  tls_config {
    insecure_skip_verify = true
  }
}

// The AWS Prometheus federates this relay with a fixed filter
// (match[]='{job="integrations/cadvisor"}'), and that federate config has no
// source-of-truth repo we can extend. So tag the worker series with that job
// label — the only way to make them cross to the AWS store without rebuilding
// the (un-sourced) AWS Prometheus config. Distinct metric names (rustpricing_*),
// so no collision with the actual cAdvisor series.
prometheus.relabel "rustpricing_federable" {
  forward_to = [prometheus.remote_write.relay.receiver]

  rule {
    target_label = "job"
    replacement  = "integrations/cadvisor"
  }
}

// Local short-retention relay (monitoring-prometheus-relay, :9528) that buffers
// on-prem remote_write and forwards on to the AWS Prometheus.
prometheus.remote_write "relay" {
  endpoint {
    url = "http://192.168.164.184:9528/api/v1/write"
  }
}
