    {
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "description": "Overall system health rollup per server. Warning or Critical indicates a subsystem issue.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "index": 0, "text": "OK" },
                "1": { "color": "orange", "index": 1, "text": "Warning" },
                "2": { "color": "red", "index": 2, "text": "Critical" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          },
          "links": [
            {
              "title": "View iDRAC",
              "url": "/d/idrac-crown?var-instance=${__field.labels.instance}",
              "targetBlank": false
            }
          ],
          "noValue": "No Data"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
