  "panels": [
    {
      "id": 30,
      "type": "table",
      "title": "Pings from BH-FIREWALL",
      "description": "ICMP pings run from each site's firewall script, pushed to Pushgateway. Shows per-site reachability perspective. Manage targets at http://poc-containers:9511/ping \u2014 set Source to the firewall name.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "PBFA97CFB590B2093"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "ping_target_configured{source=\"BH-FIREWALL\"} * on(source,target,dst) group_left() site_ping_success or ping_target_configured{source=\"BH-FIREWALL\"} * 0",
          "instant": true,
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": {
            "mode": "columns"
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "exported_job": true,
              "source": true,
              "category": true
            },
            "renameByName": {
              "target": "Target",
              "dst": "Target IP",
              "Value": "Success",
              "site_ping_success": "Success",
              "ping_target_configured": "Success"
            },
            "indexByName": {
              "target": 0,
              "dst": 1,
              "Value": 2
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "NO",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "OK",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Success"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Source Site"
          }
        ]
      }
    },
