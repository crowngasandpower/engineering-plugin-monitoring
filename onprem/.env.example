# Genus SQL Server — gas (required for genus-monitor)
GENUS_GAS_HOST=
GENUS_GAS_DB=
GENUS_GAS_USER=
GENUS_GAS_PASSWORD=

# Genus SQL Server — electricity (optional)
GENUS_ELEC_HOST=
GENUS_ELEC_DB=
GENUS_ELEC_USER=
GENUS_ELEC_PASSWORD=

# Crown MySQL (EPS / GPS file-import tracking)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# EPS Redis (Horizon queue introspection)
EPS_REDIS_HOST=
EPS_REDIS_PORT=6379
EPS_REDIS_PASSWORD=
EPS_REDIS_PREFIX=eps_horizon:

# PRTG (network monitoring read-through)
PRTG_URL=
PRTG_API_TOKEN=

# Dell PowerStore (genus-monitor ad-hoc queries — legacy)
POWERSTORE_HOST=
POWERSTORE_USER=
POWERSTORE_PASSWORD=

# Dell PowerStore exporter — shared credentials, one ADDRESS+NAME pair per array
# POWERSTORE_API_VERSION: use "v3" for PowerStore OS 3.x, leave as "1.0" for 2.x
POWERSTORE_API_VERSION=1.0
POWERSTORE_EXPORTER_USER=readonly
POWERSTORE_EXPORTER_PASSWORD=
POWERSTORE_1_ADDRESS=HQ-DC-SAN1-P500T.crowngp.local
POWERSTORE_1_NAME=HQ-DC-SAN1-P500T
POWERSTORE_2_ADDRESS=HQ-DC-SAN2-P500T.crowngp.local
POWERSTORE_2_NAME=HQ-DC-SAN2-P500T
POWERSTORE_3_ADDRESS=HQ-DC-SAN3-P500T.crowngp.local
POWERSTORE_3_NAME=HQ-DC-SAN3-P500T
POWERSTORE_4_ADDRESS=HQ-DC-SAN4-P500T.crowngp.local
POWERSTORE_4_NAME=HQ-DC-SAN4-P500T

# Ubibot temperature sensors — one numbered block per sensor
UBIBOT_1_CHANNEL_ID=
UBIBOT_1_API_KEY=
UBIBOT_1_NAME=
UBIBOT_2_CHANNEL_ID=
UBIBOT_2_API_KEY=
UBIBOT_2_NAME=
UBIBOT_3_CHANNEL_ID=
UBIBOT_3_API_KEY=
UBIBOT_3_NAME=
UBIBOT_4_CHANNEL_ID=
UBIBOT_4_API_KEY=
UBIBOT_4_NAME=

# VMware / vCenter (vmware-exporter + vcenter-sd)
VCENTER_HOST=
VCENTER_USER=
VCENTER_PASSWORD=
VCENTER_IGNORE_SSL=false
# How often vcenter-sd polls vCenter for VM backup timestamps, in seconds (default: 60)
# VCENTER_SD_POLL_INTERVAL=60

# iDRAC credentials (used by idrac-exporter for all hosts unless overridden per-host in idrac.yml)
IDRAC_USERNAME=
IDRAC_PASSWORD=

# Grafana admin password (defaults to crown2026 if unset).
# Also used by the Prometheus image (images/prometheus/entrypoint.sh) as the
# bearer token for the grafana-alerts federation scrape. On the Prometheus
# container, set this to a Viewer-role service account token rather than the
# actual admin password (create via Grafana → Administration → Service accounts).
GRAFANA_ADMIN_PASSWORD=

# Grafana LDAP bind (used by ldap.toml)
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=

# Grafana Teams notification webhook (optional, blank disables)
TEAMS_WEBHOOK_URL=

# PagerDuty Events API v2 integration key for the Platform team service
# (from PagerDuty service → Integrations). Add a separate key if other teams
# are added as contact points in future.
PAGERDUTY_PLATFORM_INTEGRATION_KEY=

# Error Diagnosis Service
# Separate Anthropic API key — not shared with review/bugs services
ANTHROPIC_API_KEY_DIAGNOSIS=
# Optional: override the Claude model (default: claude-sonnet-4-6)
# DIAGNOSIS_CLAUDE_MODEL=claude-sonnet-4-6

# Jira credentials for auto-ticket creation
JIRA_EMAIL=
JIRA_API_TOKEN=
# JIRA_PROJECT=CT

# GitHub token for fetching recent commits (optional — skip if blank)
GITHUB_TOKEN=

# Teams webhook for diagnosis notifications (separate channel from general alerts)
DIAGNOSIS_TEAMS_WEBHOOK_URL=

# Cooldown between re-diagnoses for the same alert (default: 4 hours)
# DIAGNOSIS_COOLDOWN_HOURS=4

# UniFi Site Manager — fleet overview via api.ui.com (single key covers all sites)
UNIFI_API_KEY=

# UniFi local controllers — per-controller API keys, direct via SDWAN
# UNIFI_{N}_SITE defaults to "default" — only set if you have multiple named sites
UNIFI_1_URL=
UNIFI_1_NAME=
UNIFI_1_API_KEY=
UNIFI_1_SITE=default
UNIFI_2_URL=
UNIFI_2_NAME=
UNIFI_2_API_KEY=
UNIFI_2_SITE=default
UNIFI_3_URL=
UNIFI_3_NAME=
UNIFI_3_API_KEY=
UNIFI_3_SITE=default
UNIFI_4_URL=
UNIFI_4_NAME=
UNIFI_4_API_KEY=
UNIFI_4_SITE=default

# Dell OS10 switches — RESTCONF API (add blocks for OS10_2..4 as needed)
OS10_USER=readonly
OS10_PASSWORD=
OS10_1_ADDRESS=
OS10_1_NAME=hq-sw1
