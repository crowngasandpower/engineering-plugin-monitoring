// Auto-redeploy the on-prem monitoring footprint on poc-containers when
// `master` changes, and trigger the AWS-side rebuild of the Grafana/Loki/
// Prometheus images. Automates the existing manual `git pull + docker compose
// up` of the live stacks — no change to how/where anything runs.
//
// On-prem (via SSH to the host — NOT the mounted docker socket — so compose
// bind-mounts resolve against the real host filesystem):
//   project `monitoring`            <- onprem/docker-compose.yml              (exporters + genus-monitor + postgres/postgrest + pushgateway)
//   project `monitoring-collectors` <- onprem/collectors-compose.yml          (metrics-proxy + alloy: the AWS bridge/relays)
//   project `file-gateway`          <- onprem/file-gateway/docker-compose.yml (S3 gateway over the NFS mounts)
//
// AWS: starts the `crown-eng-mcp-monitoring-build` CodeBuild project (builds
// images/{grafana,loki,prometheus} -> ECR -> force-new-deployment on ECS). It
// has no GitHub webhook, so this job is its trigger. Run via the aws-cli docker
// image (the Jenkins container has the docker socket but no aws binary), using a
// tightly-scoped key (codebuild:StartBuild on this one project).
//
// `up -d --build` rebuilds the custom exporters so code changes deploy. This
// is safe now that powerstore-exporter's Dockerfile clones its pinned upstream
// at build time (it previously needed a manually-cloned powerstore-monitor/
// dir absent from a clean checkout, which broke --build). Layer caching keeps
// repeat builds fast; only changed build contexts actually rebuild.
//
// Prereqs (Jenkins/host, set up outside this repo):
//   - SSH credential `poc-containers-ssh` (root on poc-containers; runs docker).
//   - AWS credential `monitoring-codebuild-aws` (key scoped to StartBuild on the
//     CodeBuild project).
//   - DEPLOY_PATH is the live checkout of this repo (already present, running).
pipeline {
    agent any

    triggers {
        pollSCM('H/5 * * * *')
    }

    options {
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timestamps()
    }

    environment {
        // Builds run inside the Jenkins container on poc-containers, which can't
        // resolve the `poc-containers` hostname — use the host LAN IP and the
        // `root` user the deploy key (`poc-containers-ssh`) is authorized for.
        POC_SERVER = 'root@192.168.164.184'
        POC_SSH_CREDENTIAL_ID = 'poc-containers-ssh'
        DEPLOY_PATH = '/home/docker/engineering-plugin-monitoring'
        AWS_CRED = 'monitoring-codebuild-aws'
        CODEBUILD_PROJECT = 'crown-eng-mcp-monitoring-build'
        AWS_REGION = 'eu-west-2'
    }

    stages {
        stage('Redeploy on-prem collectors') {
            when { branch 'master' }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    sshagent(credentials: [env.POC_SSH_CREDENTIAL_ID]) {
                        sh """
                            ssh -o StrictHostKeyChecking=no ${POC_SERVER} '
                                set -e
                                cd ${DEPLOY_PATH}
                                git fetch origin master
                                git reset --hard origin/master
                                cd onprem
                                docker compose -p monitoring            -f docker-compose.yml     up -d --build --remove-orphans
                                docker compose -p monitoring-collectors -f collectors-compose.yml up -d
                                cd file-gateway && docker compose -p file-gateway up -d --build
                            '
                        """
                    }
                }
            }
        }
        stage('Rebuild AWS monitoring (grafana/loki/prometheus)') {
            when { branch 'master' }
            steps {
                catchError(buildResult: 'FAILURE', stageResult: 'FAILURE') {
                    withCredentials([usernamePassword(
                        credentialsId: env.AWS_CRED,
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY',
                    )]) {
                        sh """
                            docker run --rm \
                                -e AWS_ACCESS_KEY_ID -e AWS_SECRET_ACCESS_KEY \
                                -e AWS_DEFAULT_REGION=${AWS_REGION} \
                                amazon/aws-cli codebuild start-build \
                                --project-name ${CODEBUILD_PROJECT} \
                                --query 'build.id' --output text
                        """
                    }
                }
            }
        }
    }
}
