{
  "title": "Network Connectivity",
  "uid": "crown-network-connectivity",
  "tags": ["networking", "connectivity"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "60s",
  "links": [
    {
      "title": "Manage Ping Targets",
      "url": "http://poc-containers/exemptions/ping",
      "type": "link",
      "icon": "external link",
      "targetBlank": true
    }
  ],
  "panels": [
    {
      "id": 3,
      "type": "table",
      "title": "Site Mesh Pings (from each firewall)",
      "description": "ICMP pings run from each site's firewall script, pushed to Pushgateway. Shows per-site reachability perspective. Manage targets at http://poc-containers/exemptions/ping — set Source to the firewall name.",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 10 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "site_ping_success",
          "instant": true,
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true,
              "exported_job": true
            },
            "renameByName": {
              "source": "Source Site",
              "target": "Target",
              "category": "Category",
              "dst": "IP",
              "Value": "Status"
            },
            "indexByName": {
              "source": 0,
              "target": 1,
              "category": 2,
              "dst": 3,
              "Value": 4
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
                }
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": { "text": "Down", "color": "red" },
                      "1": { "text": "Up", "color": "green" }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Source Site" }] }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Ping Targets (HQ blackbox)",
      "description": "Targets with Source='all' probed from poc-containers. Manage at http://poc-containers/exemptions/ping",
      "gridPos": { "x": 0, "y": 10, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "probe_success{job=\"ping_targets\"}",
          "instant": true,
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true },
            "renameByName": { "name": "Name", "category": "Category", "instance": "IP", "Value": "Status" },
            "indexByName": { "name": 0, "category": 1, "instance": 2, "Value": 3 }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "displayMode": "auto" } },
        "overrides": [{
          "matcher": { "id": "byName", "options": "Status" },
          "properties": [
            { "id": "custom.displayMode", "value": "color-background" },
            { "id": "color", "value": { "mode": "thresholds" } },
            { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } },
            { "id": "mappings", "value": [{ "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } }] }
          ]
        }]
      },
      "options": { "sortBy": [{ "displayName": "Category" }] }
    },
    {
      "id": 2,
      "type": "table",
      "title": "Connectivity Checks (blackbox)",
      "description": "Ad-hoc ICMP checks probed from poc-containers (HQ). Manage targets at http://poc-containers/exemptions/connectivity",
      "gridPos": { "x": 0, "y": 26, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
      "targets": [
        {
          "expr": "probe_success{job=\"connectivity_check\"}",
          "instant": true,
          "refId": "A",
          "legendFormat": ""
        }
      ],
      "transformations": [
        {
          "id": "labelsToFields",
          "options": { "mode": "columns" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "job": true,
              "__name__": true
            },
            "renameByName": {
              "name": "Name",
              "category": "Category",
              "instance": "IP",
              "Value": "Status"
            },
            "indexByName": {
              "name": 0,
              "category": 1,
              "instance": 2,
              "Value": 3
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Status" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "color", "value": { "mode": "thresholds" } },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }]
                }
              },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } }
                ]
              }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Category" }] }
    }
  ]
}
